# Hostinger / Apache — React Router (SPA)
# Garante que rotas como /formulario-residencial sirvam index.html
#
# Se o site estiver numa subpasta (ex.: exemplo.com/hub/), altere para:
#   RewriteBase /hub/

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Não reescrever ficheiros e pastas que existem (assets, index.html, etc.)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Todas as outras URLs → index.html (React Router trata a rota)
  RewriteRule ^ index.html [L]
</IfModule>

# Cache opcional para assets com hash (Vite); descomente se quiser
# <IfModule mod_headers.c>
#   <FilesMatch "\.(js|css|woff2?|svg|png|jpg|jpeg|gif|ico)$">
#     Header set Cache-Control "public, max-age=31536000, immutable"
#   </FilesMatch>
# </IfModule>
